# Copy this file to .env and fill in the values.
# Only VITE_* variables are exposed to the browser bundle.
# Never commit .env or any file containing real secrets.

# =============================================================================
# CHAIN
# =============================================================================

# Supported values: base | baseSepolia
VITE_CHAIN=base

# HTTP and WebSocket RPC endpoints (Alchemy, Infura, or any public endpoint)
VITE_HTTP_RPC_URL=
VITE_WS_RPC_URL=

# Runtime environment label used by analytics and error tracking
# Supported values: local | development | staging | production
VITE_ENVIRONMENT=local

# Set to "true" to redirect all users to the maintenance page
VITE_MAINTENANCE=false

# =============================================================================
# CONTRACT ADDRESSES
# Base Sepolia testnet defaults are pre-filled below.
# Update these for mainnet or your own contract deployment.
# =============================================================================

VITE_CONTRACT_ADDRESS_DIAMOND=0x4cad6eC90e65baBec9335cAd728DDC610c316368
VITE_CONTRACT_ADDRESS_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
VITE_CONTRACT_ADDRESS_REPUTATION_MANAGER=0xCF613e08EE1B4c2669DdCf06A7d22c9856f6Aa1D

# =============================================================================
# THIRDWEB  (required — wallet login and all contract interactions)
# https://thirdweb.com/dashboard/settings/api-keys
# =============================================================================

VITE_THIRDWEB_CLIENT_ID=""
VITE_THIRDWEB_CONTRACT_ADDRESS_AA_FACTORY=""

# =============================================================================
# DYNAMIC LABS  (required — external wallet connector: MetaMask, Phantom, etc.)
# https://app.dynamic.xyz/
# =============================================================================

VITE_DYNAMIC_PROJECT_ID=

# Supabase edge function used as a proxy for the Dynamic wallet API.
# You must deploy your own instance; see docs/dynamic-proxy.md.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# SUBGRAPH  (required — order history, routing, processing transactions)
# Deploy the P2P.me subgraph indexer and paste the endpoint here.
# Studio example: https://api.studio.thegraph.com/query/<id>/<name>/version/latest
# Gateway example: https://gateway.thegraph.com/api/<key>/deployments/id/<id>
# =============================================================================

VITE_SUBGRAPH_URL=

# =============================================================================
# PIX PROXY  (required for Brazil / BRL payments only)
# Self-host the PIX proxy server and point this variable at it.
# =============================================================================

VITE_PIX_PROXY_URL=http://localhost:8000

# =============================================================================
# BRANDING
# These values are embedded into the PWA manifest and the Thirdweb wallet modal.
# Update them for your own deployment.
# =============================================================================

VITE_APP_NAME=P2P.me
VITE_APP_URL=https://app.p2p.me
VITE_APP_FAVICON_URL=https://p2p.me/favicon.svg
VITE_TERMS_URL=https://p2p.me/tnc
VITE_PRIVACY_URL=https://p2p.me/tnc

# =============================================================================
# GAS SPONSORSHIP  (optional — users pay their own gas if not set)
# Coinbase CDP paymaster URL, or any EIP-4337 compatible paymaster.
# https://portal.cdp.coinbase.com/
# =============================================================================

VITE_BUNDLER_PAYMASTER_URL=

# =============================================================================
# BRIDGE — RANGO EXCHANGE  (optional — disables cross-chain deposit/withdraw)
# https://rango.exchange/
# VITE_RANGO_REFERRER_ADDRESS: your wallet address to receive 0.5% referral fees
# =============================================================================

VITE_RANGO_API_KEY=
VITE_RANGO_REFERRER_CODE=
VITE_RANGO_REFERRER_ADDRESS=

# =============================================================================
# ZK VERIFICATIONS — RECLAIM PROTOCOL  (optional — disables social proofs)
# https://reclaimprotocol.org/
# WARNING: VITE_RECLAIM_APP_SECRET is a private key — never commit it.
# =============================================================================

VITE_RECLAIM_APP_ID=
VITE_RECLAIM_APP_SECRET=

# =============================================================================
# FRAUD DETECTION  (optional — disables device fingerprinting if not set)
# VITE_ACTIVITY_LOG_ENCRYPTION_KEY: 32-byte hex AES-256 key.
# WARNING: never commit this value.
# VITE_FRAUD_ENGINE_REGION: asia | eu | us (SEON API region)
# =============================================================================

VITE_ACTIVITY_LOG_API_URL=
VITE_ACTIVITY_LOG_ENCRYPTION_KEY=
VITE_FRAUD_ENGINE_REGION=asia

# =============================================================================
# ANALYTICS — AMPLITUDE  (optional)
# https://amplitude.com/
# =============================================================================

VITE_AMPLITUDE_API_KEY=

# =============================================================================
# DEVICE FINGERPRINTING — FINGERPRINTJS  (optional)
# https://fingerprint.com/
# =============================================================================

VITE_FINGERPRINTJS_API_KEY=

# =============================================================================
# ERROR TRACKING — SENTRY  (optional)
# VITE_SENTRY_DSN: your project DSN from sentry.io
# VITE_SENTRY_AUTH_TOKEN: CI/build-time secret only.
#   - Do NOT put this in .env — it belongs in CI environment secrets only.
#   - Used by sentryVitePlugin during `bun run build` to upload source maps.
# VITE_SENTRY_ORG / VITE_SENTRY_PROJECT: your Sentry org and project slugs.
# =============================================================================

VITE_SENTRY_DSN=
# VITE_SENTRY_AUTH_TOKEN=   # CI secret only — never put in .env
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
